{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Kong OSS prometheus plugin metrikleri: request rate, latency, error rate, top routes, datastore durumu. datasource: VictoriaMetrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "kong-uat-overview",
  "title": "Kong UAT — Overview",
  "tags": ["kong", "uat", "medasista"],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {
          "text": "VictoriaMetrics",
          "value": "VictoriaMetrics"
        },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Service",
        "query": "label_values(kong_request_count, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Route",
        "query": "label_values(kong_request_count{service=~\"$service\"}, route)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (req/s, by Service)",
      "description": "Kong üzerinden geçen isteklerin saniye başına sayısı, service bazında ayrıştırılmış.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "drawStyle": "line"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kong_request_count{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency (ms) — p50 / p95 / p99",
      "description": "Toplam request latency (Kong + upstream). Histogram_quantile kullanır.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(kong_latency_ms_bucket{service=~\"$service\",route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kong_latency_ms_bucket{service=~\"$service\",route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kong_latency_ms_bucket{service=~\"$service\",route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate (5xx, %)",
      "description": "5xx yanıtların toplam isteğe oranı. Service bazında.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (service) (rate(kong_http_status{service=~\"$service\",code=~\"5..\"}[$__rate_interval])) / sum by (service) (rate(kong_http_status{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}} 5xx %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Status Code Dağılımı (req/s, by Code)",
      "description": "2xx / 3xx / 4xx / 5xx gruplarına göre istek oranı.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code) (rate(kong_http_status{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top Routes (son 5 dakika, total requests)",
      "description": "En çok istek alan rotalar. Route + Service + total + RPS + hata sayısı.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Requests", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "instance": true, "job": true, "code": true },
            "renameByName": {
              "route": "Route",
              "service": "Service",
              "Value": "Requests"
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (route, service) (increase(kong_request_count{service=~\"$service\"}[5m])))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kong Latency vs Upstream Latency (p95, ms)",
      "description": "Kong'un kendi işlem süresi vs upstream (RunPod) yanıt süresi. Aradaki fark Kong overhead'ini gösterir.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kong_kong_latency_ms_bucket{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "Kong overhead p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kong_upstream_latency_ms_bucket{service=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "Upstream p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Datastore Reachable",
      "description": "Kong'un DB (Postgres) bağlantı durumu. 0 = kopuk, 1 = bağlı.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(kong_datastore_reachable)",
          "legendFormat": "DB"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total Requests (5m)",
      "description": "Son 5 dakikadaki toplam istek sayısı.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kong_request_count{service=~\"$service\"}[5m]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Bandwidth (bytes/s, by Service)",
      "description": "Kong üzerinden geçen toplam trafik (request + response).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(kong_bandwidth_bytes{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
